  "faq": {
    "badge": "FAQ",
    "title": "Frequently Asked",
    "titleHighlight": "Questions",
    "items": [
      { "q": "How do I register on SICEPU?", "a": "Simply click the Register button, enter your name, campus email, and password. Your account is immediately active." },
      { "q": "Can I report more than one damage?", "a": "Of course! You can create as many reports as needed. Each report is separate and can be tracked independently." },
      { "q": "How do I track my report status?", "a": "Log in to the dashboard, click My Reports, and see the current status of each report." },
      { "q": "What photo formats are supported?", "a": "JPEG, PNG, WebP, and GIF with a maximum size of 5MB per photo. Upload up to 5 photos per report." },
      { "q": "How long is the response time?", "a": "Average response time is 24 hours. For emergency repairs, the process can be faster." },
      { "q": "Is my data safe?", "a": "Very safe. SICEPU uses JWT authentication with bcrypt password encryption." }
    ]
  },
